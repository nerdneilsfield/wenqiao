@article{zhangFastRobustIterative2022,
  author = {Zhang, Juyong and Yao, Yuxin and Deng, Bailin},
  abstract = {The iterative closest point (ICP) algorithm and its variants are a fundamental technique for rigid registration between two point sets, with wide applications in different areas from robotics to 3D reconstruction. The main drawbacks for ICP are its slow convergence, as well as its sensitivity to outliers, missing data, and partial overlaps. Recent work such as Sparse ICP achieves robustness via sparsity optimization at the cost of computational speed. In this paper, we propose a new method for robust registration with fast convergence.},
  doi = {10.1109/TPAMI.2021.3054619},
