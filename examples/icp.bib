@article{sunRealtimeFPGABasedPoint,
  author = {Sun, Hao and Xiao, Jianzhong and Chen, Fupeng and Jiang, Weixiong and Ha, Yajun},
  abstract = {Registration algorithm is essential in LiDAR (light detection and ranging) based localization and mapping systems. Unfortunately, current implementations suffer from a limited running speed of only 2 FPS (frames per second) on vehicle-embedded CPUs, primarily due to the inefficiency of the correspondence searching process. To address this issue, we propose a real-time FPGA-based point cloud registration framework equipped with fast and efficient correspondence searching capabilities. Experimental results demonstrate that our proposed framework achieves a real-time performance of 18.6 FPS. Our correspondence searching accelerator is 13.7 times faster than other FPGA implementations.},
  title = {A {{Real-time FPGA-Based Point Cloud Registration Framework}} with {{Efficient Correspondence Searching}}},
  langid = {english}
}

@article{kosugeSoCFPGAbasedIterativeclosestpointAccelerator2020,
  author = {Kosuge, Atsutake and Yamamoto, Keisuke and Akamine, Yukinori and Oshima, Takashi},
  annotation = {TLDR: An FPGA-based ICP accelerator, which achieves 11.7-times-faster object-pose estimation by a picking robot compared with the state-of-the-art technique based on K-D-tree k-nearest neighbor (NN) search and four-core CPU.},
