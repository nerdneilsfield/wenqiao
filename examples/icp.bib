  journal = {IEEE Transactions on Industrial Electronics},
  pages = {1--1},
  title = {An {{SoC-FPGA-based}} Iterative-Closest-Point Accelerator Enabling Faster Picking Robots},
  year = {2020}
}

@inproceedings{wangFPGAbasedKNNSeach2024a,
  author = {Wang, Chengliang and Huang, Zhetong and Ren, Ao and Zhang, Xun},
  abstract = {Point cloud registration assumes a crucial role in several fields, including 3D reconstruction and pose estimation. The prevalent technique for point cloud registration is Iterative Closest Point (ICP). Nonetheless, the k-nearest neighbor (kNN) search, an essential component of the ICP process, often falls short in meeting real-time requirements due to its substantial time consumption. This study proposes an FPGA-based kNN Search Accelerator, leveraging an improved LSH approach to expedite point cloud access and search. Experimental results underscore its superiority with a 120x and 15x speed-up compared to CPU and GPU implementations of the kNN process, respectively.},
  booktitle = {2024 {{IEEE International Symposium}} on {{Circuits}} and {{Systems}} ({{ISCAS}})},
  doi = {10.1109/ISCAS58744.2024.10558303},
  month = {May},
  pages = {1--5},
  title = {An {{FPGA-based kNN}} Seach Accelerator for Point Cloud Registration},
  year = {2024}
}

@article{liuHABFNNICPStreamingFPGA2025a,
  author = {Liu, Yueze and Tian, Yihong and Shen, Xiaoxu and Qian, Guanyu and Yang, Hongwei and Chen, Xuemei},
  abstract = {Three-dimensional Light Detection and Ranging (3D LiDAR) sensors are widely used in autonomous vehicles including localization, sensing, and mapping. However, their significant computational requirements remains a major limitation. This paper presents a novel high-efficiency 3D mapping method that aims to achieve faster computation speeds than CPUs while providing better energy efficiency compared to GPUs. We introduce a new processing architecture called Hardware Accelerated Brute Force Nearest Neighbor (HA-BFNN). Our FPGA implementation achieves up to 17.36x speedup in execution time compared to CPU implementations, while consuming only 3.4W of power.},
  doi = {10.1109/TCSI.2025.3609805},
  issn = {1558-0806},
  journal = {IEEE Transactions on Circuits and Systems I: Regular Papers},
  pages = {1--11},
  title = {{{HA-BFNN-ICP}} a Streaming {{FPGA}} Architecture for Energy Efficient Real-Time {{3D LiDAR}} Mapping},
  year = {2025}
}

@article{dengEnergyefficientRealtimeFPGAbased2025a,
  author = {Deng, Qi and Sun, Hao and Shu, Yuhao and Xiao, Jianzhong and Jiang, Weixiong and Wang, Hui and Ha, Yajun},
  abstract = {Point cloud registration is a fundamental task in LiDAR-based localization and mapping, widely employed in robotics and autonomous vehicles. To solve these issues, we propose a fundamentally re-architected, energy-efficient FPGA framework for real-time point cloud registration, featuring a configurable, multi-mode correspondence search engine. Experimental results demonstrate that the proposed SA-RPS-CS accelerator delivers 2.3--32.4x faster search and 1.8--26.2x higher energy efficiency than previous state-of-the-art FPGA designs, achieving real-time registration for 64-channel LiDAR at 21.5 FPS.},
  doi = {10.1145/3771768},
  issn = {1936-7406, 1936-7414},
  journal = {ACM Transactions on Reconfigurable Technology and Systems},
  month = {December},
  number = {4},
  pages = {1--30},
  title = {An Energy-Efficient and Real-Time {{FPGA-based}} Point Cloud Registration Framework with Ultra-Fast and Configurable Multi-Mode Correspondence Search},
  volume = {18},
  year = {2025}
}

@article{sugiuraFPGAacceleratedCorrespondencefreePoint2025,
  author = {Sugiura, Keisuke and Matsutani, Hiroki},
  abstract = {Point cloud registration serves as a basis for vision and robotic applications including 3D reconstruction and mapping. We propose a fast, accurate, and robust registration for low-cost embedded FPGAs. Based on a parallel and pipelined PointNet feature extractor, we develop custom accelerator cores namely PointLKCore and ReAgentCore, for two different learning-based methods. They run 58.27--63.21x faster than ARM Cortex-A53 CPU and offer 1.54--10.91x speedups over Intel Xeon CPU and Nvidia Jetson boards, while consuming less than 1 W and achieving 133.63--267.57x energy efficiency compared to Nvidia GeForce GPU.},
  doi = {10.1145/3717836},
  issn = {1936-7406, 1936-7414},
  journal = {ACM Transactions on Reconfigurable Technology and Systems},
  month = {June},
  number = {2},
  pages = {1--41},
  title = {{{FPGA-accelerated}} Correspondence-Free Point Cloud Registration with {{PointNet}} Features},
  volume = {18},
  year = {2025}
}

@article{mengFPGAbasedRealtimeLoop2025,
  author = {Meng, Shijie and Deng, Qi and Jiang, Weixiong and Huang, Jinjie and Sun, Hao and Ha, Yajun},
  abstract = {Loop closure detection (LCD) is crucial in LiDAR-based Simultaneous Localization and Mapping (SLAM) for smart vehicles, demanding both real-time performance and high-accuracy. To address the issue, we propose three key techniques to achieve a real-time FPGA-based LCD framework. Our LCD accelerator demonstrates 128.8x performance improvement across multiple datasets in various scenes and achieves the required real-time performance.},
  doi = {10.1109/TCSI.2025.3567058},
  issn = {1558-0806},
  journal = {IEEE Transactions on Circuits and Systems I: Regular Papers},
  pages = {1--14},
  title = {An {{FPGA-based}} Real-Time Loop Closure Detection Framework with Ultra-Fast Descriptor Generator},
  year = {2025}
}

