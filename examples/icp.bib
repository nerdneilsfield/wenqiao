@article{changAcceleratingNearestNeighbor2025,
  author = {Chang, Qiong and Wang, Weimin and Miyazaki, Jun},
  abstract = {The Iterative Closest Points (ICP) algorithm is the most widely used method for estimating rigid transformation in 3D point cloud registration. However, the ICP relies on repeatedly performing computationally intensive nearest neighbor searches (NNS) within 3D space. To address this issue, we propose two approximate nearest neighbor search (ANNS) acceleration strategies for efficient improvement of the processing speed of the NNS. Both the proposed methods are suited to be parallelized on GPUs with a low computational load.},
  doi = {10.1145/3716875},
  issn = {1544-3566},
  journal = {ACM Trans. Archit. Code Optim.},
  month = {March},
  number = {1},
  pages = {43:1--43:24},
  title = {Accelerating {{Nearest Neighbor Search}} in {{3D Point Cloud Registration}} on {{GPUs}}},
  volume = {22},
  year = {2025}
}

