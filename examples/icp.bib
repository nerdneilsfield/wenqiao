  journal = {IEEE Transactions on Robotics},
  month = {April},
  number = {2},
  pages = {314--333},
  shorttitle = {{{TEASER}}},
  title = {{{TEASER}}: {{Fast}} and {{Certifiable Point Cloud Registration}}},
  volume = {37},
  year = {2021}
}

