@article{arunLeastSquaresFittingTwo1987,
  author = {Arun, K. S. and Huang, T. S. and Blostein, S. D.},
  abstract = {Two point sets pi and p'i; i = 1, 2,..., N are related by p'i = Rpi + T + Ni, where R is a rotation matrix, T a translation vector, and Ni a noise vector. Given pi and p'i, we present an algorithm for finding the least-squares solution of R and T, which is based on the singular value decomposition (SVD) of a 3 x 3 matrix.},
