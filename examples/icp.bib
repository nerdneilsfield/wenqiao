@inproceedings{niePICKSRAMbasedProcessinginmemory2025,
  author = {Nie, Chen and Jiang, Chao and Xiao, Liming and Zhang, Weifeng and He, Zhezhi},
  abstract = {K-nearest neighbor (kNN) search is a fundamental operation in various point cloud applications, such as autonomous driving. However, the heavy computational intensity and memory demands of kNN search pose significant challenges for efficient implementation. We propose PICK, a processing-in-memory (PIM) architecture designed to accelerate kNN search in point cloud applications. PICK leverages bit-serial-based PIM (BS-PIM) and customized circuits to efficiently handle key operations. According to our experiments, PICK achieves 4.17x speedup and a 4.42x energy saving over the state-of-the-art design.},
  booktitle = {2025 62nd {{ACM}}/{{IEEE Design Automation Conference}} ({{DAC}})},
  doi = {10.1109/DAC63849.2025.11132408},
  month = {June},
  pages = {1--7},
  shorttitle = {{{PICK}}},
  title = {{{PICK}}: {{An SRAM-based}} Processing-in-Memory Accelerator for {{K-nearest-neighbor}} Search in Point Clouds},
  year = {2025}
}

